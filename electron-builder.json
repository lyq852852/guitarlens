{
  "appId": "com.guitarlens.app",
  "productName": "GuitarLens",
  "version": "0.5.0",
  "description": "AI Guitar Transcription Software",
  "author": "GuitarLens Team",
  "directories": {
    "output": "dist"
  },
  "files": [
    "app/**/*",
    "electron/**/*",
    "python/**/*",
    "package.json"
  ],
  "asar": false,
  "mac": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ],
    "category": "public.app-category.music"
  },
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ]
  },
  "linux": {
    "target": ["dir"],
    "category": "Audio"
  }
}
