{
  "appId": "com.guitarlens.app",
  "productName": "GuitarLens",
  "version": "0.5.0",
  "description": "AI Guitar Transcription Software - Automatic tab generation from audio",
  "author": "GuitarLens Team",
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": [
    "build/**/*",
    "electron/**/*",
    "python/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "name": "guitarlens"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.music",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist"
  },
  "dmg": {
    "iconSize": 100,
    "contents": [
      {
        "x": 110,
        "y": 150,
        "type": "file"
      },
      {
        "x": 240,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 500,
      "height": 300
    }
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "GuitarLens"
  },
  "portable": {
    "artifactName": "${productName}-${version}-Portable.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "lyq852852",
    "repo": "guitarlens"
  }
}
